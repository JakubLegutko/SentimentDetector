{
  "manifest_version": 3,
  "name": "Objectivity Gauge",
  "description": "Analyzes the objectivity of text using a switchable BERT-based model or a lexicon fallback.",
  "version": "2.1.0",
  "permissions": [],
  "host_permissions": [
    "https://huggingface.co/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Objectivity Gauge"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "vendor/vader.js",
        "scripts/transformersLoader.js",
        "scripts/newLexicon.js",
        "scripts/objectivityAnalyzer.js",
        "scripts/contentScript.js"
      ],
      "css": [
        "styles/panel.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "vendor/transformers.min.js",
        "vendor/vader.js",
        "models/*",
        "models/deberta_objectivity/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}